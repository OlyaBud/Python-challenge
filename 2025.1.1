'''
Пока SantaGPT был не в себе, он поменял пин-код на холодильнике Деда Мороза. А это непростой холодильник! В нем лежит запас волшебных леденцов, которые помогают исполнять желания детей и взрослых. Леденцы делают людей храбрее, умнее или добрее, в зависимости от вкуса.

К счастью, одна из белочек успела увидеть, как SantaGPT вводил новый пин-код. Однако она сказала, что каждая из увиденных ею цифр может быть соседней цифрой (по горизонтали или вертикали, но не по диагонали). Напишите функцию crack_pincode(), которая принимает на вход строковый аргумент pincode, который сообщает белочка, и возвращает список всех возможных вариантов пин-кода. Порядок вариантов неважен.
'''
from itertools import permutations, product

def crack_pincode(pw):
    dict = {'1' : {1, 2, 4},
            '2' : {1, 2, 3, 5},
            '3' : {2, 3, 6},
            '4' : {1, 4, 5, 7},
            '5' : {2, 4, 5, 6, 8},
            '6' : {3, 5, 6, 9},
            '7' : {4, 7, 8},
            '8' : {5, 7, 8, 9, 0},
            '9' : {6, 8, 9},
            '0' : {0, 8}}
    diapason = [dict[c] for c in pw]
    return [''.join(map(str, num)) for num in product(*diapason)]
password = input()
print(crack_pincode(password))
